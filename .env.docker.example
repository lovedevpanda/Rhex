# =============================================================================
# Rhex Docker Compose env example
# -----------------------------------------------------------------------------
# 使用说明：
#   1. 复制为 `.env`
#   2. 优先修改下方【必填】和【推荐修改】区块
#   3. 下方【可选】区块大多已有 docker-compose 默认值，不改通常也能启动
#   4. 如果修改了 POSTGRES_*，必须同步修改 DATABASE_URL
# =============================================================================


# =============================================================================
# 【必填】核心运行参数
# 缺少这些变量会导致 setup / web / worker 启动失败，或运行时直接报错
# =============================================================================

# PostgreSQL 连接串
# Docker Compose 默认数据库主机名是 `postgres`
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/bbs?schema=public

# Redis 连接串
# Docker Compose 默认 Redis 主机名是 `redis`
REDIS_URL=redis://redis:6379

# Session / 鉴权签名密钥，请替换为足够长的随机字符串
SESSION_SECRET=replace-with-a-long-random-secret

# 验证码签名密钥，请替换为足够长的随机字符串
CAPTCHA_SECRET_KEY=replace-with-a-long-random-secret


# =============================================================================
# 【推荐修改】建议按你的环境覆盖
# 不改通常也能启动，但生产环境建议至少检查一遍
# =============================================================================

# 站点绝对地址
# 三个变量按优先级读取：NEXT_PUBLIC_SITE_URL > SITE_URL > APP_URL
# 一般保留一个也可以；这里三个都给出来，便于直接覆盖
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
APP_URL=http://localhost:3000

# 首次初始化管理员账号
# 仅首次 seed 时生效；管理员已存在后会被忽略
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe_123456
SEED_ADMIN_EMAIL=admin@rhex.im
SEED_ADMIN_NICKNAME=Admin

# Docker Compose 内置 PostgreSQL 的密码
# 强烈建议修改，并同步更新上面的 DATABASE_URL
POSTGRES_PASSWORD=postgres


# =============================================================================
# 【可选】Docker / Compose 默认项
# 不改通常也能启动；只有在端口、主机名、时区、数据库名等需要覆盖时再改
# =============================================================================

# Web 容器监听地址与端口
HOSTNAME=0.0.0.0
PORT=3000

# 生产推荐 worker-only；当前 Compose 已分离 web / worker，保持默认即可
BACKGROUND_JOB_WEB_RUNTIME=worker-only

# PostgreSQL 容器参数
POSTGRES_DB=bbs
POSTGRES_USER=postgres
POSTGRES_PORT=5432

# Redis 宿主机映射端口
REDIS_PORT=6379

# 容器时区
TZ=Asia/Shanghai
